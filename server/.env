# XAMPP MySQL local configuration
# If your MySQL root user has no password (default XAMPP), use the empty password form below.
# If you set a password, replace after `root:` accordingly.
DATABASE_URL="mysql://root:@127.0.0.1:3306/ceylon_travo"

# JSON Web Token secret (change to a strong random value in production)
JWT_SECRET="replace_this_with_a_strong_secret"

# Server port
PORT=4000
