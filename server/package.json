    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "prisma": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.5.6",
    "@types/cors": "^2.8.15",
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.2"
    ,"@types/multer": "^1.4.7"
  }
