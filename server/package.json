{
  "name": "ceylon-travo-server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx prisma migrate dev --name init && ts-node-dev --respawn --transpile-only src/server.ts",
